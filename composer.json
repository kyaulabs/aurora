{
	"name": "kyaulabs/aurora",
	"description": "Aurora — PHP template framework for use with HTML5/AJAX.",
	"type": "project",
	"require": {
		"php": ">=8.5"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "*",
		"pestphp/pest": "*",
		"pestphp/pest-plugin-arch": "*",
		"pestphp/pest-plugin-browser": "*"
	},
	"autoload-dev": {
		"classmap": ["tests/"]
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	}
}
